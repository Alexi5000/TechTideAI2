      "agentId": "ceo",
      "tier": "ceo",
      "category": "multi-step",
      "difficulty": 3,
      "input": {
        "prompt": "Translate this company mission into exactly three quarterly objectives and one risk: 'Help small professional-services firms adopt AI agents safely.'",
        "format": "object"
      },
      "expected": {
        "jsonSchema": {
          "type": "object",
          "required": [
            "objectives",
            "risk"
          ],
          "properties": {
            "objectives": {
              "type": "array",
              "items": {
                "type": "string"
              },
              "minimum": 3
            },
            "risk": {
              "type": "string"
            }
          }
        },
        "rubric": "Output must include exactly three quarterly objectives and one risk. Objectives should be measurable, time-bounded, and aligned to safe AI adoption for small firms.",
        "assertions": [
          "Exactly 3 objectives are listed",
          "Each objective is measurable and time-bounded",
          "Each objective explicitly relates to safe AI adoption",
          "Risk is concrete (named failure mode, not 'general concerns')"
